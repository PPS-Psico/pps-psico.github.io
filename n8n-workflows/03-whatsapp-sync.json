{
  "name": "PPS — 03 WhatsApp Sync",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 5 * * *" }] }
      },
      "id": "cron",
      "name": "Cron 5am diario",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://pps-hermes.n8n-blas.com.ar/tasks/sync_whatsapp_backup",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"since_days\": 7, \"exclude_media\": true, \"pps_label\": \"PPS\"}",
        "options": { "timeout": 1200000 }
      },
      "id": "post-hermes",
      "name": "Hermes — sync whatsapp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300],
      "credentials": {
        "httpHeaderAuth": { "id": "gFp9uRkrXVHk7EEs", "name": "Hermes-PPS Token" }
      }
    }
  ],
  "connections": {
    "Cron 5am diario": {
      "main": [[{ "node": "Hermes — sync whatsapp", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1", "timezone": "America/Argentina/Buenos_Aires" }
}

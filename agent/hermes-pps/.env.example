# Copiar a .env y completar. NUNCA commitear el .env real.

# ---- LLM (OpenRouter, compartido con automatizacion-uflo) ----
# Recomendado: generar una subkey "pps-hermes" en https://openrouter.ai/keys
# para poder cortarla sin afectar el otro proyecto.
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
HERMES_MODEL=deepseek/deepseek-v4-flash
HERMES_MODEL_FALLBACK=anthropic/claude-haiku-4.5

# ---- Supabase (mismo proyecto que el panel) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# IMPORTANTE: service_role solo aquí en el VPS, jamás en el frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJ...

# ---- Identidad institucional ----
HERMES_OPERATOR_EMAIL=blas.rivera@uflouniversidad.edu.ar
HERMES_OPERATOR_NAME=Blas Rivera
HERMES_INSTITUTION=UFLO - Coordinacion de PPS (Psicologia)

# ---- Modo de operacion ----
# shadow  = observa, propone, nunca ejecuta
# assist  = redacta borradores, sigue sin enviar
# (jamas: auto-send)
HERMES_MODE=shadow

# ---- Verificacion de doble pasada ----
# En verify_finalizacion, una segunda llamada al LLM audita el veredicto de la
# primera antes de persistir (idea del verifier node del modo Swarm de Hermes
# Agent / Nous Research). Pensado para acreditaciones: bajar el riesgo de un
# falso "verified". Cuesta ~1 llamada extra por verificacion (centavos).
# 1 = activado (default) · 0 = una sola pasada.
HERMES_DOUBLE_CHECK_VERIFY=1

# ---- Scheduler interno (regeneracion automatica) ----
# Hermes regenera solo cada manana el PLAN DEL DIA (tablero "Hoy con Hermes")
# y, como respaldo, el daily brief si n8n no lo genero. Corre dentro del
# contenedor; no necesita configurar n8n aparte.
HERMES_SCHEDULER_ENABLED=1
# Offset horario vs UTC, en horas. Argentina = -3.
HERMES_TZ_OFFSET=-3
# Hora local (HH:MM) para regenerar el plan del dia.
HERMES_PLAN_TODAY_AT=08:05
# Hora local (HH:MM) para el brief de respaldo.
HERMES_DAILY_BRIEF_AT=08:30
# 1 = genera el brief SOLO si no hay uno de hoy (no pisa el de n8n). 0 = nunca.
HERMES_DAILY_BRIEF_FALLBACK=1
# Borradores de correo: se generan ANTES del plan para que éste los detecte.
HERMES_DRAFT_EMAILS_ENABLED=1
HERMES_DRAFT_EMAILS_AT=07:55
HERMES_DRAFT_EMAILS_LIMIT=40

# ---- Vault Obsidian ----
VAULT_PATH=/vault

# ---- Servidor HTTP ----
HTTP_PORT=8080
# Token compartido con n8n para autenticar requests internos (X-Hermes-Token).
HERMES_INTERNAL_TOKEN=cambiame-por-un-token-largo-aleatorio

# ---- Gmail: acciones salientes (panel → Hermes → n8n) ----
# Webhook del workflow n8n "05-gmail-actions" que ejecuta responder/archivar/leer
# usando la credencial Gmail OAuth2 (que vive en n8n, no acá). Si se deja vacío,
# las acciones de Gmail devuelven 503 y el panel degrada a solo-lectura.
GMAIL_ACTION_WEBHOOK_URL=https://n8n-blas.com.ar/webhook/gmail-actions
# Token opcional que Hermes envía en X-Hermes-Token al webhook (recomendado).
GMAIL_ACTION_WEBHOOK_TOKEN=cambiame-por-un-token-largo-aleatorio

# ---- Traefik Basic Auth (htpasswd) ----
# Generar: htpasswd -nb blas TU_PASS  -> escapar cada '$' como '$$'
BASIC_AUTH_USERS=blas:$$apr1$$XXXXX$$XXXXXXXXXXXXXXXXXXXX

# ---- WhatsApp E2E backup ----
# Llave de 64 caracteres hex que viste cuando activaste el backup E2E en WhatsApp.
# Si la perdés, los backups de Drive no se pueden desencriptar nunca más.
WHATSAPP_E2E_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Email propietario del backup (el del WhatsApp). Solo informativo, no se usa en código.
WHATSAPP_OWNER_EMAIL=blas.r7@gmail.com
